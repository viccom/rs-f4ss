{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/refs/heads/main/tauri/tooling/cli/schema.json",
  "productName": "rs-f4ss",
  "version": "0.1.0",
  "identifier": "com.dufs.mount",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "rs-f4ss",
        "width": 800,
        "height": 600,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  }
}
